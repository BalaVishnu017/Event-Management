# ─── Firebase (Frontend) ───────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Weather API ───────────────────────────────────────────
VITE_WEATHER_API_KEY=your_weatherapi_com_key

# ─── Backend API (used by Vite/frontend) ───────────────────
VITE_API_BASE_URL=http://localhost:5000/api

# ─── Backend Server ────────────────────────────────────────
PORT=5000
MONGODB_URI=mongodb://localhost:27017/smart-event-planner
WEATHER_API_KEY=your_weatherapi_com_key

# ─── CORS (comma-separated list of allowed frontend URLs) ──
CLIENT_ORIGIN=http://localhost:5173

# ─── Firebase Admin (Backend Auth) ─────────────────────────
# Option A: path to the downloaded service account JSON file (local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option B: paste the ENTIRE contents of the JSON as a single line (cloud/Render)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
